VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_MAPBOX_PUBLIC_TOKEN="pk.your-mapbox-token"

# Build-time module flags (cf. src/lib/buildFlags.ts and AUDIT_20260507 § 5).
# In dev (`bun run dev`) all flags default to ON. In a prod build
# (`bun run build`) scope-creep modules default to OFF unless set to "true"
# here. QualiRépar v1/v2 default to OFF in any environment.
VITE_FEATURE_AI_CMO="false"
VITE_FEATURE_BLOG_AUTO="false"
VITE_FEATURE_SOCIAL_BOOSTER="false"
VITE_FEATURE_LANDING_BUILDER="false"
VITE_FEATURE_GAMIFICATION="false"
VITE_FEATURE_QUALIREPAR_V1="false"
VITE_FEATURE_QUALIREPAR_V2="false"

# SMS Gateway (Android SMS Gateway - secrets Supabase Edge Functions)
# Ces variables sont configurées via `supabase secrets set` (voir docs/DEPLOYMENT.md)
SMS_GATEWAY_URL="https://api.sms-gate.app/3rdparty/v1"
SMS_GATEWAY_USERNAME="your-gateway-username"
SMS_GATEWAY_PASSWORD="your-gateway-password"
